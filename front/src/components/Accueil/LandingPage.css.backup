/* ═══════════════════════════════════════════════
   LandingPage.css  –  BirthReminder
   ═══════════════════════════════════════════════ */

/* ── Root & entrance animation ─────────────────── */
.lp-root {
    min-height: 100vh;
    background-color: var(--bg-secondary);
    color: var(--text-primary);
    display: flex;
    flex-direction: column;
    align-items: center;
    overflow-x: hidden;
    position: relative;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.6s ease, transform 0.6s ease;
}

.lp-root.lp-loaded {
    opacity: 1;
    transform: translateY(0);
}

/* ── Ambient gradient blobs ─────────────────────── */
.lp-blob {
    position: fixed;
    border-radius: 50%;
    filter: blur(120px);
    pointer-events: none;
    z-index: 0;
    opacity: 0.18;
}

.lp-blob-1 {
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, #6c63ff, #e040fb);
    top: -150px;
    right: -100px;
    animation: blobFloat 8s ease-in-out infinite;
}

.lp-blob-2 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, #f97316, #ec4899);
    bottom: 100px;
    left: -120px;
    animation: blobFloat 10s ease-in-out infinite reverse;
}

@keyframes blobFloat {

    0%,
    100% {
        transform: translateY(0) scale(1);
    }

    50% {
        transform: translateY(30px) scale(1.05);
    }
}

/* ── HERO ───────────────────────────────────────── */
.lp-hero {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 3rem;
    gap: 1.5rem;
    width: 100%;
    max-width: 720px;
    text-align: center;
}

.lp-logo {
    height: 260px;
    filter: drop-shadow(0 20px 40px rgba(108, 99, 255, 0.35));
    animation: logoEntry 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    animation-delay: 0.2s;
}

@keyframes logoEntry {
    from {
        opacity: 0;
        transform: scale(0.8) translateY(-20px);
    }

    to {
        opacity: 1;
        transform: scale(1) translateY(0);
    }
}

.lp-hero-text {
    animation: fadeUp 0.7s ease both;
    animation-delay: 0.45s;
}

.lp-tagline {
    font-size: 1.25rem;
    color: var(--text-secondary);
    margin-bottom: 2rem;
    line-height: 1.6;
}

.lp-cta-row {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
}

.lp-btn-primary {
    font-size: 1.05rem;
    font-weight: 700;
    padding: 12px 28px;
    background: linear-gradient(135deg, var(--primary), #8b5cf6);
    color: #fff;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 18px rgba(99, 102, 241, 0.45);
}

.lp-btn-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(99, 102, 241, 0.55);
}

.lp-btn-ghost {
    font-size: 1.05rem;
    font-weight: 600;
    padding: 12px 28px;
    background: transparent;
    color: var(--text-primary);
    border: 2px solid rgba(255, 255, 255, 0.18);
    border-radius: 10px;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s, transform 0.2s;
}

.lp-btn-ghost:hover {
    border-color: var(--primary);
    background: rgba(99, 102, 241, 0.1);
    transform: translateY(-3px);
}

/* ── STATS ──────────────────────────────────────── */
.lp-stats {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    width: 100%;
    max-width: 860px;
    padding: 2.5rem 1.5rem 0;
    animation: fadeUp 0.7s ease both;
    animation-delay: 0.65s;
}

.lp-stat-card {
    background: var(--bg-card, rgba(255, 255, 255, 0.04));
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    padding: 1.5rem 1rem;
    text-align: center;
    transition: transform 0.25s, box-shadow 0.25s;
    backdrop-filter: blur(8px);
}

.lp-stat-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.25);
}

/* Highlight card for "aujourd'hui" */
.lp-stat-today {
    border-color: rgba(249, 115, 22, 0.4);
    background: rgba(249, 115, 22, 0.08);
}

.lp-stat-emoji {
    font-size: 1.8rem;
    display: block;
    margin-bottom: 0.5rem;
}

.lp-stat-number {
    font-size: 2.4rem;
    font-weight: 800;
    background: linear-gradient(135deg, #fff 30%, var(--primary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
    margin-bottom: 0.35rem;
}

.lp-stat-today .lp-stat-number {
    background: linear-gradient(135deg, #f97316, #ec4899);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.lp-stat-label {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-secondary);
}

/* ── FEATURES ───────────────────────────────────── */
.lp-features {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    width: 100%;
    max-width: 860px;
    padding: 1.5rem 1.5rem 0;
    animation: fadeUp 0.7s ease both;
    animation-delay: 0.85s;
}

.lp-feature {
    background: var(--bg-card, rgba(255, 255, 255, 0.03));
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 14px;
    padding: 1.5rem 1rem;
    text-align: center;
    transition: transform 0.25s, box-shadow 0.25s;
}

.lp-feature:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.2);
}

.lp-feature-icon {
    font-size: 2rem;
    display: block;
    margin-bottom: 0.75rem;
}

.lp-feature h3 {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
}

.lp-feature p {
    font-size: 0.82rem;
    color: var(--text-secondary);
    line-height: 1.55;
}

/* ── FOOTER ─────────────────────────────────────── */
/* ── Skeleton loader for stats ──────────────────── */
.lp-stat-skeleton {
    display: inline-block;
    width: 48px;
    height: 36px;
    background: linear-gradient(90deg, rgba(255, 255, 255, 0.08) 25%, rgba(255, 255, 255, 0.16) 50%, rgba(255, 255, 255, 0.08) 75%);
    background-size: 200% 100%;
    border-radius: 6px;
    animation: shimmer 1.4s infinite;
}

@keyframes shimmer {
    0% {
        background-position: 200% 0;
    }

    100% {
        background-position: -200% 0;
    }
}

/* ── Stats error message ────────────────────────── */
.lp-stats-error {
    font-size: 0.78rem;
    color: #f87171;
    margin-top: 0.5rem;
}

/* ── FOOTER ─────────────────────────────────────── */
.lp-footer {
    position: relative;
    z-index: 1;
    margin-top: auto;
    padding: 2rem 1rem;
    text-align: center;
    color: var(--text-secondary);
    font-size: 0.8rem;
}

/* ── Shared keyframe ────────────────────────────── */
@keyframes fadeUp {
    from {
        opacity: 0;
        transform: translateY(20px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }
}

/* ── Responsive ─────────────────────────────────── */
@media (max-width: 768px) {

    .lp-stats,
    .lp-features {
        grid-template-columns: repeat(2, 1fr);
    }

    .lp-logo {
        height: 180px;
    }

    .lp-stat-number {
        font-size: 1.9rem;
    }
}

@media (max-width: 480px) {
    .lp-stats {
        grid-template-columns: repeat(2, 1fr);
    }

    .lp-features {
        grid-template-columns: 1fr 1fr;
    }

    .lp-logo {
        height: 140px;
    }

    .lp-tagline {
        font-size: 1rem;
        padding: 0 1rem;
    }
}

/* ── Stats context label ────────────────────────── */
.lp-stats-context {
    grid-column: 1 / -1;
    text-align: center;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-secondary);
    margin-bottom: 0.25rem;
}

/* ── Stats grid wrapper ─────────────────────────── */
.lp-stats-grid {
    display: contents;
    /* hérite le grid du parent .lp-stats */
}

/* ── Badge 🔥 sur la card aujourd'hui ───────────── */
.lp-stat-badge {
    position: absolute;
    top: -8px;
    right: -8px;
    font-size: 1rem;
    animation: badgePop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    animation-delay: 1.4s;
    opacity: 0;
}

@keyframes badgePop {
    from {
        opacity: 0;
        transform: scale(0);
    }

    to {
        opacity: 1;
        transform: scale(1);
    }
}

.lp-stat-card {
    position: relative;
    /* nécessaire pour le badge absolu */
}